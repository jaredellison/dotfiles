# vim: ft=sh :

# Git
## Git aliases from http://gitimmersion.com/lab_11.html
alias gs='git status '
alias ga='git add '
alias gb='git branch '
alias gc='git commit'
alias gcam='git commit --amend'
alias gd='git diff'
alias gds="git diff --staged"
alias gco='git checkout '
alias gk='gitk --all&'

alias gbr="git for-each-ref --count=30 --sort=-committerdate refs/ --format=' - %(refname:short)'"
alias gr="git restore "

# Show changed words aka "git diff word"
alias gdw="git diff --word-diff "
# Show changed characters aka "git diff char"
alias gdc="git diff --word-diff-regex=."

fzf-git-branch() {
    git rev-parse HEAD > /dev/null 2>&1 || return

    git branch --color=always --all --sort=-committerdate |
        grep -v HEAD |
        fzf --height 50% --ansi --no-multi --preview-window right:65% \
            --preview 'git log -n 50 --color=always --date=short --pretty="format:%C(auto)%cd %h%d %s" $(sed "s/.* //" <<< {})' |
        sed "s/.* //"
}

fzf-git-checkout() {
    git rev-parse HEAD > /dev/null 2>&1 || return

    local branch

    branch=$(fzf-git-branch)
    if [[ "$branch" = "" ]]; then
        echo "No branch selected."
        return
    fi

    # If branch name starts with 'remotes/' then it is a remote branch. By
    # using --track and a remote branch name, it is the same as:
    # git checkout -b branchName --track origin/branchName
    if [[ "$branch" = 'remotes/'* ]]; then
        git checkout --track $branch
    else
        git checkout $branch;
    fi
}

alias gb='fzf-git-branch'
alias gcob='fzf-git-checkout'

# Misc
alias portz='echo "lsof -nP +c 15 | grep LISTEN" && lsof -nP +c 15 | grep LISTEN'
alias ls='ls -FG'
alias jestdb="npx -n '--inspect-brk' jest --run-in-band"

# Tool preferences
alias vim='nvim'

# Sort iterm config file by keys and separate ones with color in the name to the end
# usage:  `sort_iterm_config iterm-file.json`
sort_iterm_config() {
  jq '
    to_entries
    | (map(select(.key | test("color$"; "i") | not)) | sort_by(.key))
      +
      (map(select(.key | test("color$"; "i"))) | sort_by(.key))
    | from_entries
  ' "$@"
}